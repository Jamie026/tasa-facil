<main class="container-fluid px-0">
    <section class="parallax-container">
        <video class="parallax-multimedia" src="./img/presentacion.mp4" autoplay muted loop></video>
        <div class="item-center">
            <p class="title animate__animated animate__backInUp">Bienvenido a Tasa Fácil</p>
            <a class="btn btn-light rounded rounded-4 fs-5 px-3 my-3" href="#card-form">
                Calcula el precio de tu inmueble aquí
            </a>
        </div>
    </section>
    <section class="container my-5" id="card-form">
        <div class="row justify-content-center align-items-center">
            <div class="col-12">
                <div class="card mt-4 border border-3 border-dark rounded">
                    <div class="row">
                        <div class="col-sm-12 col-md-6">
                            <div id="mapa"></div>
                        </div>
                        <div class="col-sm-12 col-md-6">
                            <div class="card-body px-5">
                                <h5 class="card-title text-center my-2 w-100">Evaluación de Viabilidad</h5>
                                <h6 class="card-subtitle my-4 text-body-secondary text-center w-100">Ingrese todos los datos
                                    solicitados</h6>
                                <form class="row form px-0 g-3 needs-validation" method="POST" action="./viabilidad" novalidate id="formViabilidad">
                                    <input type="hidden" name="segmento" id="segmento" value="0">
                                    <div class="col-sm-12 col-md-6 mb-4">
                                        <input type="email" class="form-control" name="email" id="email"
                                            placeholder="Correo Electrónico" required>
                                        <div id="validationEmail" class="invalid-feedback">
                                            Debe ingresar su correo Electrónico
                                        </div>
                                    </div>
                                    <div class="col-sm-12 col-md-6 mb-4">
                                        <input type="number" id="telefono" name="telefono" class="form-control"
                                            placeholder="Teléfono (Opcional)">
                                    </div>
                                    <div class="col-sm-12 col-md-6 mb-4">
                                        <input type="text" class="form-control" name="direccion" id="direccion"
                                            placeholder="Calle o Avenida" required>
                                        <div id="validationDireccion" class="invalid-feedback">
                                            Debe ingresar la direccion
                                        </div>
                                    </div>
                                    <div class="col-sm-12 col-md-6 mb-4">
                                        <input type="text" class="form-control" name="distrito" id="distrito" placeholder="Distrito"
                                            required>
                                        <div id="validationDistrito" class="invalid-feedback">
                                            Debe ingresar el distrito
                                        </div>
                                    </div>
                                    <div class="col-12 mb-4">
                                        <button class="btn btn-secondary w-100" type="button" id="ubicar">Registrar ubicación</button>
                                    </div>
                                    <div class="col-12 mb-4">
                                        <input type="text" class="form-control" name="ubicacion" id="ubicacionInput" placeholder="Ubicación Registrada"
                                            onkeydown="event.preventDefault()" autocomplete="off" required>
                                        <div id="validationUbicacion" class="invalid-feedback">
                                            Debe registrar la ubicación
                                        </div>
                                    </div>
                                    <div class="col-12 mb-2">
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="posicion"
                                                id="medianero" value="medianero" checked>
                                            <label class="form-check-label" for="medianero">Medianero</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="posicion"
                                                id="esquina" value="esquina">
                                            <label class="form-check-label" for="esquina">Esquina</label>
                                        </div>
                                    </div>
                                    <div class="col-12 mb-2">
                                        <input type="number" placeholder="Área (metros cuadrados)" class="form-control inputNumber" name="area" min="{{adminData.area_minima}}"
                                            max="{{adminData.area_maxima}}" id="area" required>
                                        <input type="range" class="form-range inputRange" name="area" min="{{adminData.area_minima}}"
                                            max="{{adminData.area_maxima}}" id="area">
                                        <div id="validationArea" class="invalid-feedback">
                                            Debe indicar el área
                                        </div>
                                    </div>
                                    <div class="col-12 mb-2">
                                        <input type="number" placeholder="Altura máxima (pisos)" class="form-control inputNumber" name="altura" min="{{adminData.altura_minima_estandar}}"
                                            max="{{adminData.altura_maxima_estandar}}" id="altura" required>
                                        <input type="range" class="form-range inputRange" name="altura" min="{{adminData.altura_minima_estandar}}"
                                            max="{{adminData.altura_maxima_estandar}}" id="altura">
                                        <div id="validationAltura" class="invalid-feedback">
                                            Debe indicar la altura
                                        </div>
                                    </div>
                                    <div class="col-12 mb-2">
                                        <input type="number" placeholder="Precio por metro cuadrado en $" name="precio_m2" class="form-control inputNumber"
                                            min="{{adminData.precio_m2_usd_terreno_cliente_minimo}}" max="{{adminData.precio_m2_usd_terreno_cliente_maximo}}" id="precio" required>
                                        <input type="range" name="precio_m2" class="form-range inputRange"
                                            min="{{adminData.precio_m2_usd_terreno_cliente_minimo}}" max="{{adminData.precio_m2_usd_terreno_cliente_maximo}}" id="precio">
                                        <div id="validationPrecio" class="invalid-feedback">
                                            Debe indicar el precio
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="form-check">
                                            <label class="form-check-label">
                                                De acuerdo con los términos y condiciones
                                            </label>
                                            <input class="form-check-input" type="checkbox" value="" required>
                                            <div id="invalidCheckFeedback" class="invalid-feedback">
                                                Debe aceptar antes de enviar el formulario
                                            </div>
                                        </div>
                                    </div>
                                    <button type="submit" class="btn btn-primary">Evaluar</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

{{> footer}}