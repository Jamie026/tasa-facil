<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Resultado</title>
        <link rel="stylesheet" href="https://redin.onrender.com/css/style.css" />
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
        <script src="https://redin.onrender.com/js/plotly.js" charset="utf-8" async></script>
    </head>
    <body>
        <main class="container-fluid">
            <div class="row">
                <section class="col-12">
                    <img class="mx-3 my-5" src="https://redin.onrender.com/img/banner-dark.png" height="30" width="180" alt="Logo"/>
                </section>
                {{#each this}}
                    <section class="col-12">
                        {{#if imageMapa}}
                            <div class="row">
                                <div class="col-12">
                                    <p class="title mx-auto mt-5 mb-3">Plano de localización del predio</p>
                                </div>
                                <div class="col-12">
                                    <div class="text-center mb-5">
                                        <img src="{{imageMapa}}" alt="Mapa" class="img-fluid border border-dark border-4"/>
                                    </div>
                                </div>
                            </div>
                        {{/if}}
                        {{#if evaluacion}}
                            {{#with this.evaluacion}}
                                {{#each this}}
                                    {{#if @key}}
                                        <table class="table table-data w-75 mx-auto">
                                            <tbody>
                                                <tr>
                                                    <th class="subtitle text-capitalize" colspan="2">{{@key}}</th>
                                                </tr>
                                                {{#each this}}
                                                    <tr>
                                                        <td class="normal w-50 text-start text-capitalize">{{clave}}</td>
                                                        <td class="normal w-50">{{valor}}</td>
                                                    </tr>
                                                {{/each}}
                                            </tbody>
                                        </table>
                                    {{/if}}
                                {{/each}}
                            {{/with}}
                        {{/if}}
                        {{#if admin}}
                            {{#with this.graficaData}}
                                <div id="open"></div>
                                <div id="graficaData" class="w-100" data-grafica="{{this}}"></div>
                            {{/with}}
                        {{else}}
                            <div class="container mt-5">
                                <p class="normal text-start">Consideraciones:</p> 
                                <p class="normal text-start">1. Para que un proyecto sea viable para un promotor o inversionista, el % minimo  de negociación del margen es 10%.</p>
                                <p class="normal text-start">2. Los Valores de ingresos y egresos considerados en la evaluación son referenciales al estándar del mercado.</p>
                                <p class="normal text-start">3. Para mayor detalle del valor de su predio, contactenos para poder encontrarle el mejor inversor,  al Telefono 991154824</p>
                            </div>
                        {{/if}}
                    </section>
                {{/each}}
            </div>
        </main>
        <script src="https://redin.onrender.com/js/viabilidad.js" async></script>
    </body>
</html>