<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Resultado</title>
        <link rel="stylesheet" href="https://redin.onrender.com/css/style.css"/>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
    </head>
    <body style="background: white;">
        <main class="container">
            <section class="w-100" style="background-color: black;">
                <img style="margin: 20px" src="https://redin.onrender.com/img/banner.png" height="30" width="180" alt="Logo"/>
            </section>
            <section class="w-100" style="margin-top: 50px; margin-bottom: 50px">
                <p class="title" style="margin-bottom: 20px;">Solicitud de contacto recibida</p>
            </section>
            <section class="w-75">
                <form class="form" style="margin-left: 120px; border: black solid 3px; padding: 50px; border-radius: 5px;">
                    {{#each this}}
                        {{#if solicitud}}
                            {{#with this.solicitud}}
                                <div class="mb-3">
                                    <label class="form-label">Nombre o Razón Social</label>
                                    <input value="{{this.nombre}}" type="text" class="w-100" style="display: inline-block; padding: 12px 20px; border: 1px solid #ccc; border-radius: 4px;"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Teléfono</label>
                                    <input value="{{this.telefono}}" type="text" class="w-100" style="display: inline-block; padding: 12px 20px; border: 1px solid #ccc; border-radius: 4px;"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Correo Electrónico</label>
                                    <input value="{{this.email}}" type="email" class="w-100" style="display: inline-block; padding: 12px 20px; border: 1px solid #ccc; border-radius: 4px;"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Motivo de contacto</label>
                                    <input value="{{this.motivo}}" type="text" class="w-100" style="display: inline-block; padding: 12px 20px; border: 1px solid #ccc; border-radius: 4px;"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Descripcion detalla de la solicitud</label>
                                    <textarea class="w-100" style="display: inline-block; padding: 12px 20px; border: 1px solid #ccc; border-radius: 4px;">{{this.solicitud}}</textarea>
                                </div>
                            {{/with}}
                        {{/if}}
                    {{/each}}
                </form>
            </section>
        </main>
    </body>
</html>